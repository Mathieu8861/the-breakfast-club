# =====================================================
# ENVIRONMENT VARIABLES — placeholders only
# Real values go in Vercel Dashboard → Settings → Env Vars
# NEVER commit the real values to Git
# =====================================================

# Meta Pixel ID (public, can be in code — but kept here for consistency)
META_PIXEL_ID=1582702526170106

# Meta Conversion API Access Token (SENSITIVE — set this only in Vercel)
# Generated from: Events Manager → Pixel → Settings → Conversions API → Generate token
META_ACCESS_TOKEN=replace_me_in_vercel_dashboard

# SumUp API key (private, sup_sk_...) — for fetching transaction details
SUMUP_API_KEY=replace_me_in_vercel_dashboard

# SumUp webhook signing secret — verifies webhook authenticity
SUMUP_WEBHOOK_SECRET=replace_me_in_vercel_dashboard

# SumUp merchant code (visible top-right of dashboard)
SUMUP_MERCHANT_CODE=MDYF9FMT
